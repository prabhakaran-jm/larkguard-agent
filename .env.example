# Required: GitHub personal access token with repo read access
GITHUB_TOKEN=ghp_your_token_here

# Optional defaults used when owner/repo are omitted
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=your-repo

# getlark.ai (hackathon sponsor) — https://docs.getlark.ai
# API key: dashboard → Settings → API Keys
GETLARK_API_KEY=
GETLARK_API_URL=https://api.getlark.ai

# Lark execution mode: fake (default) | getlark_mcp | getlark_cli | getlark_cli_live | getlark_live_check
LARK_MODE=fake

# Optional: override LARK_MODE for a single run / demo
# PRIMARY_ADAPTER_MODE=getlark_live_check

# Thin real mode: fail verify on API error instead of falling back to fake
GETLARK_STRICT_MODE=false
GETLARK_TIMEOUT_SECONDS=15
GETLARK_ENABLE_WORKFLOW_INVOKE=false
GETLARK_WORKFLOW_ID=wflw_your_smoke_workflow_id
# GETLARK_WORKFLOW_NAME=larkguard-smoke
GETLARK_ENABLE_CLI_LIVE=false
GETLARK_CLI_BIN=getlark

# Parser: deterministic (default) | truefoundry_gateway
PARSER_MODE=deterministic

# TrueFoundry AI Gateway (OpenAI-compatible) — parser layer only
# TRUEFOUNDRY_API_KEY=
# TRUEFOUNDRY_GATEWAY_BASE_URL=https://gateway.truefoundry.ai
# TRUEFOUNDRY_MODEL=openai-main/gpt-4o-mini
# TRUEFOUNDRY_STRICT_MODE=false
# TRUEFOUNDRY_TIMEOUT_SECONDS=20
