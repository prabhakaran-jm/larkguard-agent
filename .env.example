# Required: GitHub personal access token with repo read access
GITHUB_TOKEN=ghp_your_token_here

# Optional defaults used when owner/repo are omitted
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=your-repo

# getlark.ai (hackathon sponsor) — https://docs.getlark.ai
# API key: dashboard → Settings → API Keys
GETLARK_API_KEY=
GETLARK_API_URL=https://api.getlark.ai

# Lark execution mode: fake (default) | getlark_mcp | getlark_cli
LARK_MODE=fake
